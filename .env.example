POSTGRES_DB=statisfactory
POSTGRES_USER=statisfactory_user
POSTGRES_PASSWORD=<your_secure_password>
DATABASE_URL=postgresql+asyncpg://statisfactory_user:<your_secure_password>@db/statisfactory

# Docker image references and tag (tag applied to both images if specific vars are unset)
IMAGE_TAG=latest
BACKEND_IMAGE=ghcr.io/floley/statisfaction-backend
FRONTEND_IMAGE=ghcr.io/floley/statisfaction-frontend

# Comma-separated list of allowed frontend origins for CORS
ALLOWED_ORIGINS=http://localhost:5174

# Frontend: URL of the backend API (used at build time by Vite)
VITE_API_BASE_URL=http://localhost:8001/api
