# Tailscale IP (production only — used for port bindings and URLs)
TAILSCALE_IP=100.109.197.38

# Lowercase GitHub owner name (used to reference GHCR images in docker-compose.yml)
OWNER_LC=your-github-username

# PostgreSQL credentials
POSTGRES_USER=statisfaction
POSTGRES_PASSWORD=statisfaction
POSTGRES_DB=statisfactiondb

# Backend database URL
DATABASE_URL=postgresql://statisfaction:statisfaction@db:5490/statisfactiondb

# Test database URL (for running pytest locally against the dev compose DB)
# TEST_DATABASE_URL=postgresql://statisfaction:statisfaction@localhost:5490/statisfactiondb

# Frontend API URL (must be reachable from the browser)
# Production (Tailscale):
VITE_API_URL=http://100.109.197.38:7745
# Dev (localhost):
# VITE_API_URL=http://localhost:7745

# Allowed CORS origins for the backend (comma-separated)
# Production (Tailscale):
CORS_ORIGINS=http://100.109.197.38:7746
# Dev (localhost):
# CORS_ORIGINS=http://localhost:7746
