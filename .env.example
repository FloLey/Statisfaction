# PostgreSQL credentials
POSTGRES_USER=statisfaction
POSTGRES_PASSWORD=statisfaction
POSTGRES_DB=statisfactiondb

# Backend database URL (used inside Docker network — service name 'db' as host)
DATABASE_URL=postgresql+asyncpg://statisfaction:statisfaction@db:5432/statisfactiondb

# Test database URL (used locally when running pytest outside Docker)
TEST_DATABASE_URL=postgresql+asyncpg://statisfaction:statisfaction@localhost:5433/statisfactiondb_test

# Tailscale IP (production only — used for port bindings and URLs)
TAILSCALE_IP=100.109.197.38

# Lowercase GitHub owner name (used to reference GHCR images in docker-compose.yml)
OWNER_LC=your-github-username

# Frontend API URL (must be reachable from the browser)
# Production (Tailscale):
VITE_API_URL=http://100.109.197.38:8001
# Dev (localhost):
# VITE_API_URL=http://localhost:8001

# Allowed CORS origins for the backend (comma-separated)
# Production (Tailscale):
CORS_ORIGINS=http://100.109.197.38:5174
# Dev (localhost):
# CORS_ORIGINS=http://localhost:5174
