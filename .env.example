# PostgreSQL credentials
POSTGRES_USER=todo
POSTGRES_PASSWORD=todo
POSTGRES_DB=tododb

# Backend database URL (used inside Docker network — service name 'db' as host)
DATABASE_URL=postgresql+asyncpg://todo:todo@db:5432/tododb

# Test database URL (used locally when running pytest outside Docker)
TEST_DATABASE_URL=postgresql+asyncpg://todo:todo@localhost:5432/tododb_test

# Frontend API URL (must be reachable from the browser)
# Production (Tailscale):
VITE_API_URL=http://100.109.197.38:8001
# Dev (localhost):
# VITE_API_URL=http://localhost:8001
